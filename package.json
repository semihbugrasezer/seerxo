{
  "name": "seerxo",
  "version": "1.12.7",
  "description": "MCP server for AI-powered Etsy SEO generation. Use with Claude Desktop to generate optimized product titles, descriptions, and tags in seconds.",
  "type": "module",
  "main": "mcp-server.js",
  "bin": {
    "seerxo-mcp": "bin/seerxo-mcp.js",
    "seerxo": "bin/seerxo.js"
  },
  "scripts": {
    "start": "node bin/seerxo.js",
    "test": "NODE_ENV=test node --test",
    "lint": "node --check mcp-server.js && node --check utils.js && node --check src/mcp/tools.js && node --check src/formatters/listing.js && node --check scripts/validate-package-files.mjs",
    "build": "node scripts/validate-package-files.mjs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude-desktop",
    "claude-code",
    "claude-skill",
    "cli",
    "etsy",
    "etsy-seo",
    "seo",
    "ai",
    "claude",
    "gemini",
    "product-optimization",
    "e-commerce",
    "content-generation"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/semihbugrasezer/seerxo.git"
  },
  "bugs": {
    "url": "https://github.com/semihbugrasezer/seerxo/issues"
  },
  "homepage": "https://www.seerxo.com",
  "author": "Seerxo",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "open": "^11.0.0"
  },
  "files": [
    "mcp-server.js",
    "src",
    "bin/seerxo.js",
    "bin/seerxo-mcp.js",
    "skills/seerxo-etsy-seo",
    "utils.js",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "semantic-release": "^25.0.3"
  },
  "overrides": {
    "ip-address": "10.1.1",
    "npm": "11.18.0",
    "@actions/http-client": {
      "undici": "^6.27.0"
    },
    "@semantic-release/github": {
      "undici": "^7.28.0"
    }
  },
  "mcpName": "io.github.semihbugrasezer/seerxo"
